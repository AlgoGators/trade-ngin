{
  "_description": "BPGV_ROTATION_PORTFOLIO - Macro regime rotation strategy using building permit growth volatility",
  "portfolio_id": "BPGV_ROTATION_PORTFOLIO",
  "initial_capital": 100000,
  "reserve_capital_pct": 0.05,
  "strategies": {
    "BPGV_ROTATION": {
      "enabled_backtest": true,
      "enabled_live": false,
      "default_allocation": 1.0,
      "type": "BPGVRotationStrategy",
      "symbols": ["SPY", "QQQ", "XLK", "SMH", "IWM", "XHB", "IYR", "EQR", "TLT", "GLD", "BIL", "DBMF"],
      "config": {
        "macro_csv_path": "data/macro/bpgv_regime.csv",
        "rebalance_day_of_month": 18,
        "momentum_lookback_days": 63,
        "momentum_tilt_scale": 0.40,
        "homebuilder_tilt_scale": 0.20,
        "breakout_sma_window": 50,
        "crash_threshold": -0.07,
        "crash_lookback_days": 5,
        "crash_override_calendar_days": 14,
        "crash_defensive_weight": 0.45,
        "allow_fractional_shares": true,
        "risk_on_symbols": ["SPY", "QQQ", "XLK", "SMH", "IWM", "XHB", "IYR", "EQR"],
        "risk_off_symbols": ["TLT", "GLD"],
        "_comment_cash": "Remediation Fix 1: BIL and DBMF live in a cash bucket with zero base weight in normal regimes. They only accumulate weight during crash override and serve as TSM risk-free reference.",
        "cash_symbols": ["BIL", "DBMF"],
        "crash_override": {
          "_comment_basket": "Tier-1 Change 1: cash + bonds + gold + managed futures. SPY is NOT in the defensive basket (baseline bug: SPY was 32% and the single largest realized loser).",
          "defensive_weights": {
            "BIL": 0.40,
            "TLT": 0.25,
            "GLD": 0.20,
            "DBMF": 0.15
          },
          "zero_symbols": ["SPY", "QQQ", "XLK", "SMH", "IWM", "XHB", "IYR", "EQR"],
          "splice_fallback_symbol": "BIL",
          "trigger": {
            "_comment": "Change 3: volatility-scaled trigger. Fires when 5d z-score < -2.0 AND 60d sigma percentile > 40th.",
            "method": "volatility_scaled",
            "lookback_days": 60,
            "k_sigma": 2.0,
            "vol_gate_percentile": 0.40,
            "vol_gate_window": 504,
            "min_history_days": 80
          },
          "exit": {
            "_comment": "Change 4: signal-contingent exit. 5-day min hold, 5-day confirmation window, composite score > 0.55.",
            "method": "signal_contingent",
            "min_hold_days": 5,
            "confirmation_days": 5,
            "exit_threshold": 0.55,
            "max_hold_days": null,
            "trend_symbol": "SPY",
            "weights": {
              "trend": 0.50,
              "vol_norm": 0.25,
              "recov": 0.25
            }
          }
        },
        "rebalance": {
          "_comment": "Tier-2: monthly_only mode available (code-path guarded) but disabled in active config — produced negative targets under the portfolio executor's establishment path. Using wide tolerance bands from remediation.",
          "mode": "tolerance_band",
          "drift_abs_trigger": 0.025,
          "drift_rel_trigger": 0.50,
          "halfway_rule": true,
          "exit_fully_on_zero_target": true,
          "enter_fully_on_zero_current": true
        },
        "momentum": {
          "_comment": "Tier-2 W3 reverted \u2014 worse performance when combined with W2.",
          "tsm_gate_enabled": true,
          "tsm_lookback_days": 252,
          "tsm_risk_free_symbol": "BIL",
          "tsm_fail_open_on_short_history": true,
          "tsm_tolerance": 0.05,
          "xsec_lookback_days": 126,
          "xsec_use_vol_scaling": true,
          "xsec_vol_window_days": 126,
          "xsec_sigma_floor": 0.05,
          "xsec_tau": 0.40,
          "xsec_weight_floor": 0.50
        },
        "breakout": {
          "_comment": "Tier-2 W2 reverted \u2014 worse performance when combined with W3.",
          "mode": "graded",
          "sma_window": 200,
          "atr_window": 14,
          "atr_k": 2.0,
          "confirmation_days": 3,
          "graded_weighting": true,
          "index_gate_enabled": false,
          "index_gate_symbol": "SPY",
          "index_gate_floor": 0.25,
          "fail_open_on_short_history": true
        }
      }
    }
  }
}
