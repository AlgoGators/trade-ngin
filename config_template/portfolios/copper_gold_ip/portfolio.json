{
    "_description": "COPPER_GOLD_IP_PORTFOLIO - Copper/Gold ratio macro regime strategy for futures",
    "portfolio_id": "COPPER_GOLD_IP_PORTFOLIO",
    "initial_capital": 500000,
    "reserve_capital_pct": 0.10,
    "strategies": {
        "COPPER_GOLD_IP": {
            "enabled_backtest": true,
            "enabled_live": false,
            "default_allocation": 1.0,
            "type": "CopperGoldIPStrategy",
            "symbols": ["HG", "GC", "CL", "SI", "ZN", "UB", "MNQ"],
            "config": {
                "macro_csv_path": "data/macro/copper_gold_daily.csv",
                "roc_window": 20,
                "ma_fast": 10,
                "ma_slow": 50,
                "zscore_window": 120,
                "zscore_threshold": 0.5,
                "w1": 0.33,
                "w2": 0.33,
                "w3": 0.34,
                "min_holding_period": 5,
                "spx_momentum_lookback": 60,
                "breakeven_lookback": 20,
                "liquidity_zscore_window": 60,
                "liquidity_threshold": -1.5,
                "dxy_momentum_lookback": 20,
                "dxy_momentum_threshold": 0.03,
                "china_cli_avg_window": 65,
                "china_cli_threshold": -2.0,
                "correlation_window": 20,
                "correlation_threshold": 0.70,
                "leverage_target": 2.0,
                "max_margin_utilization": 0.50,
                "drawdown_warning_pct": 0.10,
                "drawdown_stop_pct": 0.15,
                "max_single_equity_notional": 0.20,
                "max_single_commodity_notional": 0.15,
                "max_total_equity_notional": 0.35,
                "max_total_commodity_notional": 0.40
            }
        }
    }
}
